# OpenAI API Configuration (for assistant_api)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# GigaChat API Configuration (for assistant_giga)
# Get your credentials from: https://developers.sber.ru/gigachat
GIGACHAT_AUTH_KEY=your-basic-auth-token-here
GIGACHAT_RQUID=your-request-uid-here

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual API keys
# 3. Never commit .env to git (it's in .gitignore)
